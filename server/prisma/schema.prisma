// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ALUMNI
  ADMIN
  SUPER_ADMIN
}

enum SchoolCategory {
  School_of_Engineering
  School_of_law
  School_of_agriculture
  School_of_Medicine
}

enum EventType {
  OFFLINE
  ONLINE
}

enum EventVisibility {
  GLOBAL
  DEPARTMENTAL
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  password       String
  role           UserRole        @default(USER)
  schoolCategory SchoolCategory?
  isVerified     Boolean         @default(false)
  createdEvents  Event[]
  registrations  Registration[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Event {
  id            Int             @id @default(autoincrement())
  name          String
  description   String?
  organizedBy   String
  place         String
  imageUrl      String?         @default("https://images.unsplash.com/photo-1740065592671-9cb593ee9b78?q=80&w=1173&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D")
  eventType     EventType
  visibility    EventVisibility
  startDate     DateTime
  endDate       DateTime
  createdById   Int
  createdBy     User            @relation(fields: [createdById], references: [id], onDelete: Restrict)
  registrations Registration[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Registration {
  id               Int      @id @default(autoincrement())
  eventId          Int
  userId           Int
  name             String
  email            String
  countryCode      String?
  contactNo        String?
  companyOrCollege String?
  graduationYear   String?
  linkedInUrl      String?

  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([eventId, userId])
}